.DS_Store
__pycache__/
.venv/

!.gitignore
!results/
!results/integrated/
!results/integrated/**/

*.pyc

# Gate 3 raw / private evidence — never auto-commit
datasets/controlled/raw/**
datasets/controlled/raw-private/**
datasets/controlled/staged/**
!datasets/controlled/raw/.gitkeep
!datasets/controlled/raw-private/.gitkeep
!datasets/controlled/raw-private/README.md
!datasets/controlled/staged/.gitkeep
*.device-private.json
*.raw-session.json

# Sanitized sessions stay local until Edmund approves publication
datasets/controlled/sanitized/**
!datasets/controlled/sanitized/.gitkeep

# Calibration raw reports may include sanitized copies — keep measurement JSON local
results/calibration/**/sanitized_*.json
results/calibration/sanitized_*.json
results/calibration/**/_ignored_raw/
results/rehearsal/**/_ignored_raw/
results/rehearsal/**/sanitized_*.json
results/android/_ignored_local/
results/rehearsal/**/_ignored_sanitized/

# Release candidate archives (local only)
release/dist/**

# Ephemeral Gate 4 dry-run outputs
results/gate4/gate4-run-*/
