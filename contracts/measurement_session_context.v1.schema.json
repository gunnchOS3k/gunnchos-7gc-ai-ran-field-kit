{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gunnchos3k.org/schemas/measurement_session_context.v1.schema.json",
  "title": "Measurement Session Context v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_name",
    "schema_version",
    "session_id",
    "run_id",
    "collection_day_id",
    "location_category",
    "named_test_zone",
    "indoor_outdoor",
    "stationary_or_moving",
    "network_condition",
    "network_type",
    "workload_profile",
    "planned_duration_seconds",
    "actual_duration_seconds",
    "start_timestamp",
    "end_timestamp",
    "device_category",
    "collector_version",
    "consent_receipt_id",
    "environmental_notes",
    "degradation_method",
    "operator_notes",
    "protocol_deviation",
    "evidence_level"
  ],
  "properties": {
    "schema_name": {
      "const": "gunnchos.measurement_session_context"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^1\\.\\d+\\.\\d+$"
    },
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "collection_day_id": {
      "type": "string",
      "minLength": 1
    },
    "location_category": {
      "type": "string",
      "enum": [
        "home_or_private_indoor",
        "library_or_community_indoor",
        "campus_or_office_indoor",
        "outdoor_stationary",
        "transit_or_mobility",
        "other_approved_test_zone"
      ]
    },
    "named_test_zone": {
      "type": "string",
      "pattern": "^zone_[a-z0-9]+$"
    },
    "indoor_outdoor": {
      "type": "string",
      "enum": [
        "indoor",
        "outdoor",
        "mixed"
      ]
    },
    "stationary_or_moving": {
      "type": "string",
      "enum": [
        "stationary",
        "moving",
        "walking",
        "transit",
        "mixed"
      ]
    },
    "network_condition": {
      "type": "string",
      "enum": [
        "wifi_normal",
        "cellular_normal",
        "wifi_degraded",
        "local_network_degraded"
      ]
    },
    "network_type": {
      "type": "string",
      "enum": [
        "wifi",
        "cellular",
        "ethernet",
        "vpn",
        "other",
        "unknown",
        "unavailable",
        "degraded_local"
      ]
    },
    "declared_network_condition": {
      "type": "string"
    },
    "detected_network_transport": {
      "type": "string",
      "enum": [
        "wifi",
        "cellular",
        "ethernet",
        "vpn",
        "other",
        "unavailable",
        "unknown"
      ]
    },
    "session_mode": {
      "type": "string",
      "enum": [
        "CALIBRATION",
        "PILOT_REHEARSAL",
        "PILOT"
      ]
    },
    "calibration_only": {
      "type": "boolean"
    },
    "rehearsal_only": {
      "type": "boolean"
    },
    "assignment_id": {
      "type": "string"
    },
    "assignment_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "matrix_cell_id": {
      "type": "string"
    },
    "protocol_version": {
      "type": "string"
    },
    "transport_assignment_compatible": {
      "type": "boolean"
    },
    "environmental_flags": {
      "type": "object",
      "additionalProperties": {
        "type": "boolean"
      }
    },
    "workload_profile": {
      "type": "string",
      "enum": [
        "learn",
        "create",
        "sense"
      ]
    },
    "planned_duration_seconds": {
      "type": "number",
      "minimum": 1
    },
    "actual_duration_seconds": {
      "type": "number",
      "minimum": 0
    },
    "start_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "end_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "device_category": {
      "type": "string",
      "enum": [
        "phone",
        "tablet",
        "laptop",
        "kiosk"
      ]
    },
    "collector_version": {
      "type": "string",
      "minLength": 1
    },
    "consent_receipt_id": {
      "type": "string",
      "minLength": 8
    },
    "environmental_notes": {
      "type": "string"
    },
    "degradation_method": {
      "type": "string"
    },
    "operator_notes": {
      "type": "string"
    },
    "protocol_deviation": {
      "type": [
        "string",
        "null"
      ]
    },
    "evidence_level": {
      "type": "string",
      "enum": [
        "controlled_device_measurement",
        "synthetic",
        "open_data",
        "source_validated_simulation"
      ]
    },
    "collection_purpose_version": {
      "type": "string"
    },
    "privacy_policy_version": {
      "type": "string"
    },
    "consent_captured_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
