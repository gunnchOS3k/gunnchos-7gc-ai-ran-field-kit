{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gunnchos.example/schemas/gate4/result_record.schema.json",
  "title": "Gate 4 Result Record",
  "type": "object",
  "required": [
    "schema_name",
    "schema_version",
    "experiment_id",
    "component",
    "condition",
    "metric",
    "value",
    "unit",
    "evaluation_label",
    "inference_label"
  ],
  "properties": {
    "schema_name": {"const": "gunnchos.gate4_result_record"},
    "schema_version": {"type": "string", "pattern": "^1\\.0\\.0$"},
    "experiment_id": {"type": "string"},
    "component": {"type": "string"},
    "condition": {"type": "string"},
    "metric": {"type": "string"},
    "value": {"type": ["number", "string", "null"]},
    "unit": {"type": "string"},
    "evaluation_label": {
      "type": "string",
      "enum": ["infrastructure_validation_only", "scientific_evaluation"]
    },
    "inference_label": {
      "type": "string",
      "enum": ["insufficient_sample_size_for_inference", "inferential_evaluation"]
    },
    "notes": {"type": "string"}
  },
  "additionalProperties": true
}
